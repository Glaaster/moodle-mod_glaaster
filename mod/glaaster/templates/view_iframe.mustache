{{!
    @template mod_glaaster/view_iframe

    LTI activity iframe container.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * src - iframe src URL
    * allow - allow attribute string (microphone, camera, etc.)

    Example context (json):
    {
        "src": "https://example.com/launch",
        "allow": "microphone https://example.com; camera https://example.com"
    }
}}
<iframe id="contentframe"
        height="700"
        width="100%%"
        src="{{src}}"
        allow="{{allow}}"
        allowfullscreen></iframe>
