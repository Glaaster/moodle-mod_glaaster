{{!
    @template mod_glaaster/tool_proxies_tabs

    Bootstrap tab layout for tool proxy management page.

    Classes required for JS:
    * none (Bootstrap tabs handled by Moodle core)

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * tabs - array of tab objects:
    *   id       - tab panel ID
    *   label    - tab label string
    *   selected - boolean, true for the active tab
    *   content  - HTML content of the tab panel (unescaped)

    Example context (json):
    {
        "tabs": [
            {"id": "tp_configured", "label": "Configured", "selected": true, "content": "<table>...</table>"},
            {"id": "tp_pending",    "label": "Pending",    "selected": false, "content": "<table>...</table>"}
        ]
    }
}}
<ul class="nav nav-tabs" id="tp-tabs" role="tablist">
    {{#tabs}}
    <li class="nav-item" role="presentation">
        <a class="nav-link{{#selected}} active{{/selected}}"
           id="{{id}}-tab"
           data-toggle="tab"
           href="#{{id}}"
           role="tab"
           aria-controls="{{id}}"
           aria-selected="{{#selected}}true{{/selected}}{{^selected}}false{{/selected}}">{{label}}</a>
    </li>
    {{/tabs}}
</ul>
<div class="tab-content" id="tp-tabs-content">
    {{#tabs}}
    <div class="tab-pane fade{{#selected}} show active{{/selected}}"
         id="{{id}}"
         role="tabpanel"
         aria-labelledby="{{id}}-tab">
        {{{content}}}
    </div>
    {{/tabs}}
</div>
